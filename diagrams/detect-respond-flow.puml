@startuml
title Detect and Respond Workflow for H&L Development

skinparam backgroundColor #FCFCFF
skinparam shadowing false
skinparam dpi 180
skinparam padding 20
skinparam nodesep 70
skinparam ranksep 80
skinparam roundcorner 30
skinparam ArrowThickness 2

skinparam activity {
  BackgroundColor #EAF4FF
  BorderColor #2F5D8A
  FontColor #10243E
  FontSize 15
  StartColor #6EDC8C
  EndColor #FF7B89
  DiamondBackgroundColor #FFF2B2
  DiamondBorderColor #A67C00
  DiamondFontColor #4A3A00
  BarColor #6A4C93
}

start

#D7EEFF:Collect logs from authentication portals,\ncloud services, repositories,\nand critical applications;

#C8F7DC:Correlate events in centralized\nmonitoring or SIEM;

if (Suspicious behavior detected?) then (Yes)
  #FFE2B8:Open an incident record\nand begin triage;

  #FFE8CC:Classify severity, scope,\naffected assets, and\nbusiness impact;

  if (Credential or secret exposed?) then (Yes)
    #FFD2D8:Revoke keys or credentials\nimmediately;
  else (No)
    #F8D7FF:Continue technical\ninvestigation;
  endif

  #FFD6E7:Contain the threat by isolating systems,\nblocking IPs, or restricting access;

  #E6D8FF:Eradicate the root cause by patching flaws,\nremoving malicious code,\nor resetting credentials;

  #FFF0C9:Communicate with technical leads,\nmanagement, legal,\nand affected clients as needed;

  #D8F3FF:Document findings, timeline,\nactions taken, and evidence;
else (No)
  #E8F7E8:Continue monitoring and\ntune alert logic;
endif

stop
@enduml

